; Engine configuration file.
; Aqueduct (placeholder name — rename after trademark search before store submit).

config_version=5

[application]

config/name="Aqueduct"
config/description="Placeholder name; rename before store submit. Real-time pipe-routing puzzle."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

Config="*res://scripts/config.gd"
Settings="*res://scripts/settings.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/handheld/orientation=1
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_width"

[rendering]

renderer/rendering_method="mobile"
